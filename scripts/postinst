#!/bin/sh
# Runs after package.tgz is extracted to $SYNOPKG_PKGDEST.
# On fresh install, Package Center exports the install-wizard fields
# (wizard_api_key etc.) as environment variables.

PKG_DIR="${SYNOPKG_PKGDEST:-/var/packages/godaddy-ddns/target}"
CONF="$PKG_DIR/etc/godaddy-ddns.conf"

mkdir -p "$PKG_DIR/var"
chmod 755 "$PKG_DIR/bin/godaddy-ddns.sh" "$PKG_DIR/bin/godaddy-ddnsd.sh"

if [ -f /tmp/godaddy-ddns.conf.upgrade ]; then
    # Upgrade: the user's existing config wins.
    mv -f /tmp/godaddy-ddns.conf.upgrade "$CONF"
elif [ -n "$wizard_api_key" ]; then
    # Fresh install: build the config from the wizard answers.
    cat > "$CONF" <<EOF
# GoDaddy DDNS configuration (generated by the install wizard).
# Edit and restart the package to apply changes; see
# godaddy-ddns.conf.default in this directory for field docs.

API_KEY="$wizard_api_key"
API_SECRET="$wizard_api_secret"
DOMAIN="$wizard_domain"
RECORDS="${wizard_records:-@}"
TTL=600
CHECK_INTERVAL=300
LOG_CHECKS="no"
EOF
elif [ ! -f "$CONF" ]; then
    cp "$PKG_DIR/etc/godaddy-ddns.conf.default" "$CONF"
fi

# Credentials live in this file - keep it root-only.
chmod 600 "$CONF"

exit 0
