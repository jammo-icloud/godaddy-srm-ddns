package="godaddy-ddns"
version="@VERSION@"
displayname="GoDaddy DDNS"
description="Keeps GoDaddy DNS A records pointed at this router's public IP. Configure API credentials in /var/packages/godaddy-ddns/target/etc/godaddy-ddns.conf via SSH, then start the package."
maintainer="James Morris"
arch="noarch"
firmware="1.2-7742"
os_min_ver="1.2-7742"
startable="yes"
silent_install="no"
silent_upgrade="yes"
thirdparty="yes"
checksum="@CHECKSUM@"
